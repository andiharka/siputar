{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SIPUTAR",
  "version": "0.6.1",
  "identifier": "com.disperpusip.siputar",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "SIPUTAR",
        "width": 900,
        "height": 600,
        "minWidth": 700,
        "minHeight": 450,
        "center": true,
        "visible": true
      },
      {
        "label": "mini-player",
        "title": "Now Playing",
        "url": "/mini-player",
        "width": 380,
        "height": 480,
        "resizable": false,
        "alwaysOnTop": true,
        "visible": false,
        "decorations": true,
        "skipTaskbar": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/**",
          "$APPDATA/**",
          "$DOCUMENT/**",
          "$DESKTOP/**",
          "$DOWNLOAD/**",
          "/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "icons/tray-active.png",
      "icons/tray-paused.png",
      "icons/tray-activeTemplate.png",
      "icons/tray-pausedTemplate.png",
      "icons/tray-active-light.png",
      "icons/tray-paused-light.png",
      "icons/tray-active-dark.png",
      "icons/tray-paused-dark.png"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM2MzE4MkM1RUIzMThDRDkKUldUWmpESHJ4WUl4Tm41dXJxNzRMWU9IY2tzTWdRVzZUK0M0TVZjZUpLUlJPc0tpN2lmaWlxQzUK",
      "endpoints": [
        "https://github.com/andiharka/playback-announcer/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}